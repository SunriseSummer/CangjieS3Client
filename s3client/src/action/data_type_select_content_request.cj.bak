package s3client.action

/*
 *
 * @author: wangwb
 * @date: 2023-12-15
 */
public class SelectContentRequest <: ToString {
    public let expression: String
    public let expressionType: String
    public let requestProgress: ?RequestProgress
    public let inputSerialization: InputSerialization
    public let outputSerialization: OutputSerialization
    public let scanRange: ?ScanRange

    public init(
        expression!: String,
        expressionType!: String,
        requestProgress!: ?RequestProgress = None,
        inputSerialization!: InputSerialization,
        outputSerialization!: OutputSerialization,
        scanRange!: ?ScanRange = None
    ) {
        this.expression = expression
        this.expressionType = expressionType
        this.requestProgress = requestProgress
        this.inputSerialization = inputSerialization
        this.outputSerialization = outputSerialization
        this.scanRange = scanRange
    }

    public func toString(): String {
        return "SelectContentRequest(" +
            "expression=${expression}, expressionType=${expressionType}, requestProgress=${requestProgress}, inputSerialization=${inputSerialization}, " +
            "outputSerialization=${outputSerialization}, scanRange=${scanRange}" + ")"
    }
}

public class RequestProgress <: ToString {
    public let enabled: ?Bool

    public init(enabled!: ?Bool = None) {
        this.enabled = enabled
    }

    public func toString(): String {
        return "RequestProgress(enabled=${enabled})"
    }
}

public class ScanRange <: ToString {
    public let start: ?Int64
    public let end: ?Int64

    public init(
        start!: ?Int64 = None,
        end!: ?Int64 = None
    ) {
        this.start = start
        this.end = end
    }

    public func toString(): String {
        return "ScanRange(start=${start}, end=${start})"
    }
}

// -----
//
// -----

extend SelectContentRequest <: S3XmlObject<SelectContentRequest> {
    public static prop ELE_NAME: String {
        get() {
            "SelectObjectContentRequest"
        }
    }

    public func toXml(eleName: String, isRoot: Bool): String {
        let expression = this.expression.toXml("Expression")
        let expressionType = this.expressionType.toXml("ExpressionType")
        let requestProgress = this.requestProgress?.toXml() ?? ""
        let inputSerialization = this.inputSerialization.toXml()
        let outputSerialization = this.outputSerialization.toXml()
        let scanRange = this.scanRange?.toXml() ?? ""
        return "<${eleName} ${namespace(isRoot)}>${expression}${expressionType}${requestProgress}" +
            "${inputSerialization}${outputSerialization}${scanRange}</${eleName}>"
    }

    public static func fromXml(_: S3XmlElement): SelectContentRequest {
        throw UnsupportedException()
    }
}

extend RequestProgress <: S3XmlObject<RequestProgress> {
    public static prop ELE_NAME: String {
        get() {
            "RequestProgress"
        }
    }

    public func toXml(eleName: String, _: Bool): String {
        let enabled = this.enabled?.toString().toXml("Enabled") ?? ""
        return "<${eleName}>${enabled}</${eleName}>"
    }

    public static func fromXml(_: S3XmlElement): RequestProgress {
        throw UnsupportedException()
    }
}

extend ScanRange <: S3XmlObject<ScanRange> {
    public static prop ELE_NAME: String {
        get() {
            "ScanRange"
        }
    }

    public func toXml(eleName: String, _: Bool): String {
        let start = this.start?.toString().toXml("Start") ?? ""
        let end = this.end?.toString().toXml("End") ?? ""
        return "<${eleName}>${start}${end}</${eleName}>"
    }

    public static func fromXml(_: S3XmlElement): ScanRange {
        throw UnsupportedException()
    }
}
