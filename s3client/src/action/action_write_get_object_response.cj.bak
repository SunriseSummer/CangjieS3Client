//
// -----

public class WriteGetObjectResponseRequest <: AbstractS3Request {
    public let requestRoute: String
    public let requestToken: String
    public let statusCode: ?Int32
    public let errorCode: ?String
    public let errorMessage: ?String
    public let acceptRanges: ?String
    public let cacheControl: ?String
    public let contentDisposition: ?String
    public let contentEncoding: ?String
    public let contentLanguage: ?String
    public let contentLength: ?Int64
    public let contentRange: ?String
    public let contentType: ?String
    public let checksumCRC32: ?String
    public let checksumCRC32C: ?String
    public let checksumSHA1: ?String
    public let checksumSHA256: ?String
    public let deleteMarker: ?Bool
    public let etag: ?String
    public let expires: ?DateTime
    public let expiration: ?String
    public let lastModified: ?DateTime
    public let missingMeta: ?Int32
    public let metadata: ?Map<String, String>
    public let objectLockMode: ?String
    public let objectLockLegalHoldStatus: ?String
    public let objectLockRetainUntilDate: ?DateTime
    public let partsCount: ?Int32
    public let replicationStatus: ?String
    public let requestCharged: ?String
    public let restore: ?String
    public let serverSideEncryption: ?String
    public let sseCustomerAlgorithm: ?String
    public let ssekmsKeyId: ?String
    public let sseCustomerKeyMD5: ?String
    public let storageClass: ?String
    public let tagCount: ?Int32
    public let versionId: ?String
    public let bucketKeyEnabled: ?Bool

    public init(
        requestConfig!: ?S3RequestConfig = None,
        requestRoute!: String,
        requestToken!: String,
        statusCode!: ?Int32 = None,
        errorCode!: ?String = None,
        errorMessage!: ?String = None,
        acceptRanges!: ?String = None,
        cacheControl!: ?String = None,
        contentDisposition!: ?String = None,
        contentEncoding!: ?String = None,
        contentLanguage!: ?String = None,
        contentLength!: ?Int64 = None,
        contentRange!: ?String = None,
        contentType!: ?String = None,
        checksumCRC32!: ?String = None,
        checksumCRC32C!: ?String = None,
        checksumSHA1!: ?String = None,
        checksumSHA256!: ?String = None,
        deleteMarker!: ?Bool = None,
        etag!: ?String = None,
        expires!: ?DateTime = None,
        expiration!: ?String = None,
        lastModified!: ?DateTime = None,
        missingMeta!: ?Int32 = None,
        metadata!: ?Map<String, String> = None,
        objectLockMode!: ?String = None,
        objectLockLegalHoldStatus!: ?String = None,
        objectLockRetainUntilDate!: ?DateTime = None,
        partsCount!: ?Int32 = None,
        replicationStatus!: ?String = None,
        requestCharged!: ?String = None,
        restore!: ?String = None,
        serverSideEncryption!: ?String = None,
        sseCustomerAlgorithm!: ?String = None,
        ssekmsKeyId!: ?String = None,
        sseCustomerKeyMD5!: ?String = None,
        storageClass!: ?String = None,
        tagCount!: ?Int32 = None,
        versionId!: ?String = None,
        bucketKeyEnabled!: ?Bool = None
    ) {
        super(requestConfig)
        this.requestRoute = requestRoute
        this.requestToken = requestToken
        this.statusCode = statusCode
        this.errorCode = errorCode
        this.errorMessage = errorMessage
        this.acceptRanges = acceptRanges
        this.cacheControl = cacheControl
        this.contentDisposition = contentDisposition
        this.contentEncoding = contentEncoding
        this.contentLanguage = contentLanguage
        this.contentLength = contentLength
        this.contentRange = contentRange
        this.contentType = contentType
        this.checksumCRC32 = checksumCRC32
        this.checksumCRC32C = checksumCRC32C
        this.checksumSHA1 = checksumSHA1
        this.checksumSHA256 = checksumSHA256
        this.deleteMarker = deleteMarker
        this.etag = etag
        this.expires = expires
        this.expiration = expiration
        this.lastModified = lastModified
        this.missingMeta = missingMeta
        this.metadata = metadata
        this.objectLockMode = objectLockMode
        this.objectLockLegalHoldStatus = objectLockLegalHoldStatus
        this.objectLockRetainUntilDate = objectLockRetainUntilDate
        this.partsCount = partsCount
        this.replicationStatus = replicationStatus
        this.requestCharged = requestCharged
        this.restore = restore
        this.serverSideEncryption = serverSideEncryption
        this.sseCustomerAlgorithm = sseCustomerAlgorithm
        this.ssekmsKeyId = ssekmsKeyId
        this.sseCustomerKeyMD5 = sseCustomerKeyMD5
        this.storageClass = storageClass
        this.tagCount = tagCount
        this.versionId = versionId
        this.bucketKeyEnabled = bucketKeyEnabled
    }

    public func toString(): String {
        return "WriteGetObjectResponseRequest(" +
            "requestRoute=${requestRoute}, requestToken=${requestToken}, statusCode=${statusCode}, errorCode=${errorCode}, " +
            "errorMessage=${errorMessage}, acceptRanges=${acceptRanges}, cacheControl=${cacheControl}, contentDisposition=${contentDisposition}, " +
            "contentEncoding=${contentEncoding}, contentLanguage=${contentLanguage}, contentLength=${contentLength}, contentRange=${contentRange}, " +
            "contentType=${contentType}, checksumCRC32=${checksumCRC32}, checksumCRC32C=${checksumCRC32C}, checksumSHA1=${checksumSHA1}, " +
            "checksumSHA256=${checksumSHA256}, deleteMarker=${deleteMarker}, etag=${etag}, expires=${expires}, " +
            "expiration=${expiration}, lastModified=${lastModified}, missingMeta=${missingMeta}, metadata=${StringUtils.mapToString(metadata)}, " +
            "objectLockMode=${objectLockMode}, objectLockLegalHoldStatus=${objectLockLegalHoldStatus}, objectLockRetainUntilDate=${objectLockRetainUntilDate}, partsCount=${partsCount}, " +
            "replicationStatus=${replicationStatus}, requestCharged=${requestCharged}, restore=${restore}, serverSideEncryption=${serverSideEncryption}, " +
            "sseCustomerAlgorithm=${sseCustomerAlgorithm}, ssekmsKeyId=${ssekmsKeyId}, sseCustomerKeyMD5=${sseCustomerKeyMD5}, storageClass=${storageClass}, " +
            "tagCount=${tagCount}, versionId=${versionId}, bucketKeyEnabled=${bucketKeyEnabled}" + //
        ")"
    }
}

public class WriteGetObjectResponseResponse <: AbstractS3Response {
    public init(responseMetadata: S3ResponseMetadata) {
        super(responseMetadata)
    }

    public func toString(): String {
        return "WriteGetObjectResponseResponse()"
    }
}
