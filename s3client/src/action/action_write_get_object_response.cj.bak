package s3client.action

/*
 *
 * @author: wangwb
 * @date: 2023-12-15
 */
public class WriteGetObjectResponse <: AbstractS3Action<WriteGetObjectResponseRequest, WriteGetObjectResponseResponse> {
    public init(s3ClientConfigMap: ConfigMap, s3Req: WriteGetObjectResponseRequest) {
        super(s3ClientConfigMap, s3Req)
    }

    public prop name: String {
        get() {
            return "WriteGetObjectResponse"
        }
    }

    protected func marshalling(s3Req: WriteGetObjectResponseRequest): S3HttpRequestBuilder {
        let httpReq = createHttpRequest("POST", path: "/WriteGetObjectResponse")
        httpReq.addHeader(S3Constants.REQUEST_ROUTE, s3Req.requestRoute)
        httpReq.addHeader(S3Constants.REQUEST_TOKEN, s3Req.requestToken)
        httpReq.addHeader("x-amz-fwd-" + "status", s3Req.statusCode?.toString())
        httpReq.addHeader("x-amz-fwd-" + "error-code", s3Req.errorCode)
        httpReq.addHeader("x-amz-fwd-" + "error-message", s3Req.errorMessage)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.ACCEPT_RANGES, s3Req.acceptRanges)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.CACHE_CONTROL, s3Req.cacheControl)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.CONTENT_DISPOSITION, s3Req.contentDisposition)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.CONTENT_ENCODING, s3Req.contentEncoding)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.CONTENT_LANGUAGE, s3Req.contentLanguage)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.CONTENT_LENGTH, s3Req.contentLength?.toString())
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.CONTENT_RANGE, s3Req.contentRange)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.CONTENT_TYPE, s3Req.contentType)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.CHECKSUM_CRC32, s3Req.checksumCRC32)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.CHECKSUM_CRC32C, s3Req.checksumCRC32C)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.CHECKSUM_SHA1, s3Req.checksumSHA1)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.CHECKSUM_SHA256, s3Req.checksumSHA256)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.DELETE_MARKER, s3Req.deleteMarker?.toString())
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.ETAG, s3Req.etag)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.EXPIRES, s3Req.expires?.toStringRfc822())
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.EXPIRATION, s3Req.expiration)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.LAST_MODIFIED, s3Req.lastModified?.toStringRfc822())
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.MISSING_META, s3Req.missingMeta?.toString())
        match (s3Req.metadata) {
            case None => ()
            case Some(map) => for ((k, v) in map) {
                //TODO 奇怪, 好像这个不用"x-amz-fwd-header-"
                httpReq.addHeader(S3Constants.META_ + k, v)
            }
        }
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.OBJECT_LOCK_MODE, s3Req.objectLockMode)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.OBJECT_LOCK_LEGAL_HOLD_STATUS, s3Req.objectLockLegalHoldStatus
        )
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.OBJECT_LOCK_RETAIN_UNTIL_DATE,
            s3Req.objectLockRetainUntilDate?.toStringRfc822())
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.PARTS_COUNT, s3Req.partsCount?.toString())
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.REPLICATION_STATUS, s3Req.replicationStatus)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.REQUEST_CHARGED, s3Req.requestCharged)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.RESTORE, s3Req.restore)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.SERVER_SIDE_ENCRYPTION, s3Req.serverSideEncryption)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.SSE_CUSTOMER_ALGORITHM, s3Req.sseCustomerAlgorithm)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.SSEKMS_KEY_ID, s3Req.ssekmsKeyId)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.SSE_CUSTOMER_KEY_MD5, s3Req.sseCustomerKeyMD5)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.STORAGE_CLASS, s3Req.storageClass)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.TAG_COUNT, s3Req.tagCount?.toString())
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.VERSION_ID, s3Req.versionId)
        httpReq.addHeader("x-amz-fwd-header-" + S3Constants.BUCKET_KEY_ENABLED, s3Req.bucketKeyEnabled?.toString())
        return httpReq
    }

    protected func unmarshalling(httpRsp: S3HttpResponse): WriteGetObjectResponseResponse {
        return WriteGetObjectResponseResponse(S3ResponseMetadata(httpRsp.headers))
    }
}

